DISCORD_TOKEN=
DISCORD_GUILD_ID=

# Chemin optionnel vers un fichier de credentials Asterisk (format clé=valeur)
# ASTERISK_CREDENTIALS_FILE=/root/discord-asterisk-credentials.txt

ARI_BASE_URL=http://127.0.0.1:8088
ARI_USERNAME=discordbot
ARI_PASSWORD=
ARI_APPLICATION=discord-sip
PJSIP_ENDPOINT=yeastar

CALLER_ID_NAME=Discord Bridge
CALLER_ID_NUMBER=1000

AUTHORIZED_USER_IDS=
AUTHORIZED_ROLE_IDS=

# Si true, seuls les rôles/utilisateurs listés ci-dessus peuvent utiliser les commandes
# (propriétaire du serveur toujours autorisé ; administrateurs si les listes sont vides)
RESTRICT_COMMANDS_TO_AUTHORIZED_ONLY=false

# Si true, les commandes ne sont acceptées que dans le salon textuel d’un salon vocal (contrôle à l’exécution)
RESTRICT_COMMANDS_TO_VOICE_TEXT=false

# Si true, le numéro appelé est masqué dans le message Discord d’état
HIDE_CALLED_NUMBER=true

# Modèles Yeastar des numéros autorisés, séparés par des virgules (X=0-9, Z=1-9, .=longueur variable)
CALLED_NUMBER_PATTERN=0ZXXXXXXXX,09XXXXXXXX

# Masquage Discord : chiffres masqués au début et à la fin (le milieu reste visible)
CALLED_NUMBER_MASK_START=3
CALLED_NUMBER_MASK_END=3

# Caractère de masquage affiché sur Discord
# CALLED_NUMBER_MASK_CHAR=•

# Préfixe de sortie Yeastar (non affiché sur Discord) : pattern:prefix séparés par des virgules
# Les règles spécifiques avant les règles générales (0X., X., etc.)
# OUTBOUND_DIAL_RULES=0ZXXXXXXXX:8,09XXXXXXXX:9,0X.:7

# Intervalle d’actualisation du message d’appel en cours (secondes, 0 pour désactiver)
STATUS_REFRESH_INTERVAL_SECONDS=5

VOICE_CONNECTION_TIMEOUT_SECONDS=30
VOICE_DEBUG=false

CALL_TIMEOUT_SECONDS=60
MAX_CALL_DURATION_SECONDS=3600
MAX_CONCURRENT_CALLS=1
CALLS_PER_HOUR_PER_USER=5
REGISTER_COMMANDS=true
